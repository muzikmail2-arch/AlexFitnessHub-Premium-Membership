# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PAYSTACK_SECRET_KEY: Secret key for Paystack API transactions (server-side only)
PAYSTACK_SECRET_KEY=

# PAYSTACK_PUBLIC_KEY: Public key for Paystack popups (client-side and server-side)
PAYSTACK_PUBLIC_KEY=

# PAYSTACK_WEBHOOK_SECRET: Secret key used to verify webhook request signatures from Paystack
PAYSTACK_WEBHOOK_SECRET=

# APP_URL: The URL where this applet is hosted (e.g., https://alexfitnesshub.com)
APP_URL=

# YOUTUBE_API_KEY: Optional YouTube Data API key for live workout search indexer (server-side only)
YOUTUBE_API_KEY=

# VITE_TAWKTO_PROPERTY_ID: Optional property ID for Tawk.to live chat integrations (format: property_id/widget_id)
VITE_TAWKTO_PROPERTY_ID=

# ADMIN_EMAIL: Custom administrative user email (server-side only)
ADMIN_EMAIL=

# ADMIN_PASS: Custom administrative user password (server-side only)
ADMIN_PASS=


